# Optional. Enables DeepSeek-generated governance highlights and company risk evaluations.
# Keep the real API key in your local environment or Streamlit secrets; do not commit it.
# When DEEPSEEK_API_KEY is empty or the API fails, the page automatically falls back to rule/database copy.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_AI_ENABLED=1
DEEPSEEK_TIMEOUT_SECONDS=20

# Optional. Set to 1 only if your MongoDB storage quota is large enough for raw JSONL data.
# The derived query collections are much smaller and are migrated by default.
MONGODB_MIGRATE_RAW=0
