MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DATABASE=mixed_reform
MIXED_REFORM_SOURCE_ROOT=C:\Users\赖宏\Desktop\公司混改系统

# Optional. Enables Qwen/NVIDIA-generated governance highlights on the Streamlit governance module page.
# Keep the real API key in your local environment or Streamlit secrets; do not commit it.
# When QWEN_API_KEY is empty, the page automatically falls back to rule-based highlights.
QWEN_API_KEY=
QWEN_BASE_URL=https://integrate.api.nvidia.com/v1
QWEN_MODEL=qwen/qwen3-next-80b-a3b-instruct
QWEN_HIGHLIGHTS_ENABLED=1
QWEN_TIMEOUT_SECONDS=4

# Optional. Set to 1 only if your MongoDB storage quota is large enough for raw JSONL data.
# The derived query collections are much smaller and are migrated by default.
MONGODB_MIGRATE_RAW=0
